<!-- Created by Phạm Duy – Giải pháp tự động hóa thông minh. -->
<Window x:Class="SmartMacroAI.DriverInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="540" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        FontFamily="Segoe UI"
        Title="{DynamicResource ui_Drv_Title}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🎮" FontSize="32" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource ui_Drv_ModeLabel}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{DynamicResource ui_Drv_Subtitle}" Foreground="#888" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" LineHeight="22" FontSize="13" Foreground="#CCC">
            <Run Text="{DynamicResource ui_Drv_Desc1}"/><Bold Foreground="White"><Run Text="{DynamicResource ui_Drv_DescBold}"/></Bold><Run Text="{DynamicResource ui_Drv_Desc2}"/><LineBreak/><LineBreak/>
            ✅ <Run Text="{DynamicResource ui_Drv_Feat1}"/><Bold Foreground="White"><Run Text="{DynamicResource ui_Drv_Feat1Bold}"/></Bold><LineBreak/>
            ✅ <Run Text="{DynamicResource ui_Drv_Feat2}"/><LineBreak/>
            ✅ <Run Text="{DynamicResource ui_Drv_Feat3}"/><LineBreak/><LineBreak/>
            <Italic Foreground="#888"><Run Text="{DynamicResource ui_Drv_Compat}"/></Italic>
        </TextBlock>

        <!-- AMD Ryzen Warning -->
        <TextBlock Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap" VerticalAlignment="Bottom"
                   Foreground="#F9E2AF" FontSize="11"
                   Text="{DynamicResource ui_Drv_AmdNote}"/>

        <!-- Progress -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,6" Background="#333" Foreground="#4FC3F7"/>
            <TextBlock x:Name="TxtStatus" Text="" FontSize="12" Foreground="#888"/>
        </StackPanel>

        <!-- Buttons: 2 rows for clarity -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <!-- Row 1: Main actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                <Button x:Name="BtnCancel" Content="{DynamicResource ui_Drv_LaterBtn}"
                        Click="BtnCancel_Click"
                        Padding="14,7" Margin="0,0,8,0"
                        Background="#333" Foreground="#CCC" BorderBrush="#555"
                        FontSize="12"/>
                <Button x:Name="BtnInstall" Content="{DynamicResource ui_Drv_InstallBtn}"
                        Click="BtnInstall_Click"
                        Padding="14,7" IsDefault="True"
                        Background="#4FC3F7" Foreground="#1E1E2E" BorderBrush="#4FC3F7"
                        FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
            <!-- Row 2: Uninstall / Manual guide -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnManualGuide" Content="{DynamicResource ui_Drv_ManualGuideBtn}"
                        Click="BtnManualGuide_Click"
                        Padding="14,7" Margin="0,0,8,0"
                        Background="#45475A" Foreground="#F9E2AF" BorderBrush="#585B70"
                        FontSize="11"
                        ToolTip="Xem hướng dẫn gỡ thủ công khi bị khoá chuột/phím"/>
                <Button x:Name="BtnUninstall" Content="{DynamicResource ui_Drv_UninstallBtn}"
                        Click="BtnUninstall_Click"
                        Padding="14,7"
                        Background="#45475A" Foreground="#F38BA8" BorderBrush="#585B70"
                        FontSize="11"
                        ToolTip="Gỡ cài đặt driver Interception"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

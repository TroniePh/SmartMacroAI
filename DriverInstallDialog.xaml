<Window x:Class="SmartMacroAI.DriverInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Cài đặt Driver Level Mode"
        Width="500" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🎮" FontSize="32" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="Driver Level Mode" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Cho phép click/nhấn phím vào game anti-cheat"
                           Foreground="#888" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" LineHeight="22" FontSize="13" Foreground="#CCC">
            Tính năng này cần cài một <Bold Foreground="White">driver cấp hệ thống</Bold>
            để giả lập thiết bị chuột/bàn phím thật.<LineBreak/><LineBreak/>
            ✅ Hoàn toàn tự động — chỉ cần bấm <Bold Foreground="White">Cài đặt ngay</Bold><LineBreak/>
            ✅ Cần quyền Administrator (Windows sẽ hỏi 1 lần)<LineBreak/>
            ✅ Cần khởi động lại máy sau khi cài<LineBreak/><LineBreak/>
            <Italic Foreground="#888">Tương thích: MapleStory, PUBG, và các game có HackShield / EasyAntiCheat</Italic>
        </TextBlock>

        <!-- Progress -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,6" Background="#333" Foreground="#4FC3F7"/>
            <TextBlock x:Name="TxtStatus" Text="" FontSize="12" Foreground="#888"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="Để sau"
                    Click="BtnCancel_Click"
                    Padding="16,8" Margin="0,0,8,0"
                    Background="#333" Foreground="#CCC" BorderBrush="#555"/>
            <Button x:Name="BtnInstall" Content="⚡ Cài đặt ngay"
                    Click="BtnInstall_Click"
                    Padding="16,8" IsDefault="True"
                    Background="#4FC3F7" Foreground="#1E1E2E" BorderBrush="#4FC3F7"/>
        </StackPanel>
    </Grid>
</Window>

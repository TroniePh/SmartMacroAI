<Window x:Class="SmartMacroAI.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource ui_LogWin_Title}"
        Height="400" Width="680"
        MinHeight="200" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        FontFamily="Consolas"
        FontSize="12"
        Topmost="False"
        Closing="LogWindow_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="LogList"
                 Grid.Row="0"
                 Background="#1a1a1a"
                 Foreground="#d0d0d0"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.ScrollUnit="Item">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Time}"
                                   Foreground="#555555"
                                   Width="90"
                                   FontSize="11"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding MacroName}"
                                   Foreground="#4f98a3"
                                   Width="120"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{Binding Color}"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="1"
                Background="#111111"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="{DynamicResource ui_LogWin_ClearBtn}"
                        Click="BtnClear_Click"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="12"/>
                <Button Content="{DynamicResource ui_LogWin_SaveBtn}"
                        Click="BtnSave_Click"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="12"/>
                <CheckBox x:Name="ChkAutoScroll"
                          Content="{DynamicResource ui_LogWin_AutoScroll}"
                          IsChecked="{Binding AutoScroll, RelativeSource={RelativeSource AncestorType=Window}}"
                          VerticalAlignment="Center"
                          Foreground="#aaaaaa"
                          FontSize="12"
                          FontFamily="Segoe UI"/>
                <TextBlock x:Name="TxtCount"
                           VerticalAlignment="Center"
                           Foreground="#666666"
                           Margin="16,0,0,0"
                           FontSize="11"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
